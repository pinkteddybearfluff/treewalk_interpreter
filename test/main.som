import "filepath" as alias

fn getPrime(n) -> number{
    let arr = [];

    for(let i = 0;i<100;i = i+1)
        push(arr,true);

    arr[0] = false;
    arr[1] = false;

    for(let i = 2;i*i<100;i = i+1)
        for(let j = 2;j<100/i;j = j+1)
            arr[i*j] = false;

    let res = [];
    for(let i= 0;i<100;i= i+1)
        if(arr[i])
            push(res,i);
    return res;
}

println(__VERSION__);


let prime:Array[number] = getPrime(100); 

println(prime);


